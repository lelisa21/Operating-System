CC = gcc
CFLAGS = -Wall -Wextra -Iinclude

# Output binary
TARGET = scheduler

# Source files
SRC = \
src/main.c \
src/engine/cpu.c \
src/engine/scheduler.c \
src/engine/clock.c \
src/schedulers/fcfs.c \
src/schedulers/sjf.c \
src/core/input.c \
src/core/queue.c \
src/core/metrics.c \
src/core/gantt.c \
src/utils/sort.c \
src/utils/helpers.c

# Object files (auto-generated)
OBJ = $(SRC:.c=.o)

# Default build
all: $(TARGET)

# Link all object files
$(TARGET): $(OBJ)
	$(CC) $(CFLAGS) -o $(TARGET) $(OBJ)

# Compile .c to .o
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# Run program
run: $(TARGET)
	./$(TARGET)

# Clean build files
clean:
	rm -f $(OBJ) $(TARGET)

# Rebuild everything
rebuild: clean all
